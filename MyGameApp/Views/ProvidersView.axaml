<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MyGameApp.ViewModels"
             xmlns:models="using:MyGameApp.Models"
             x:Class="MyGameApp.Views.ProvidersView"
             x:DataType="vm:ProvidersViewModel">
    <Panel>
        <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="30,25"
              IsEnabled="{Binding !IsAddOpen}">
            <TextBlock Grid.Row="0" Text="Провайдери"
                       Foreground="White" FontSize="26" FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <Grid Grid.Row="1" ColumnDefinitions="*,10,Auto,10,Auto" Height="42" Margin="0,0,0,20">
                <TextBox Grid.Column="0" Watermark="Пошук за назвою"
                         Classes="DarkInput" Text="{Binding SearchText}"/>
                <Button Grid.Column="2" Width="60" Height="42"
                        Background="#3A3A3A" CornerRadius="10" BorderThickness="0"
                        Command="{Binding ToggleSortCommand}">
                    <TextBlock Text="{Binding SortLabel}" Foreground="White" FontWeight="Bold"/>
                </Button>
                <Button Grid.Column="4" Width="100" Height="42"
                        Background="#3A3A3A" CornerRadius="10" BorderThickness="0"
                        Command="{Binding AddProviderCommand}">
                    <TextBlock Text="+ Новий" Foreground="White" FontWeight="SemiBold"/>
                </Button>
            </Grid>

            <Grid Grid.Row="2" ColumnDefinitions="150,20,200,*,60" Margin="10,0,10,8">
                <TextBlock Grid.Column="0" Text="ТЕЛЕФОН" Classes="Header" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="НАЗВА / ПРЕДСТАВНИК" Classes="Header" HorizontalAlignment="Center"/>
            </Grid>

            <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Providers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="models:Provider">
                            <StackPanel>
                                <Grid ColumnDefinitions="150,20,35,200,*,60" Height="55"
                                      Margin="10,0,10,0" VerticalAlignment="Center">
                                    <TextBlock Grid.Column="0" Text="{Binding Phone}"
                                               Foreground="#E0E0E0" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <Border Grid.Column="1" Width="1" Background="White"
                                            Opacity="0.08" Margin="0,12" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Name}"
                                               Foreground="#E0E0E0" VerticalAlignment="Center"/>
                                    <Button Grid.Column="5" Classes="ArrowBtn" Margin="0,0,5,0">
                                        <TextBlock Text="→" Foreground="#FFFFFF" FontSize="18"/>
                                    </Button>
                                </Grid>
                                <Border Height="1" Background="White" Opacity="0.05"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Модальний оверлей -->
        <Panel IsVisible="{Binding IsAddOpen}">
            <Border Background="#88000000"/>
            <Border Width="420" Padding="28"
                    Background="#2B2B2B" CornerRadius="14"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    DataContext="{Binding AddForm}"
                    x:DataType="vm:AddProviderViewModel">
                <StackPanel Spacing="14">
                    <TextBlock Text="Новий провайдер" FontSize="20" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBox Watermark="Назва *" Classes="DarkInput" Text="{Binding Name}" Height="42"/>
                    <TextBox Watermark="Номер телефону *" Classes="DarkInput" Text="{Binding Phone}" Height="42"/>
                    <TextBox Watermark="Контактна особа" Classes="DarkInput" Text="{Binding ContactPerson}" Height="42"/>
                    <TextBox Watermark="Email" Classes="DarkInput" Text="{Binding Email}" Height="42"/>
                    <TextBox Watermark="Адреса" Classes="DarkInput" Text="{Binding Address}" Height="42"/>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF6B6B"
                               IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               FontSize="13" HorizontalAlignment="Center"/>
                    <Grid ColumnDefinitions="*,10,*" Margin="0,8,0,0">
                        <Button Grid.Column="0" Content="Скасувати" Height="42"
                                Background="#3A3A3A" CornerRadius="10" BorderThickness="0"
                                Foreground="#AAAAAA" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Command="{Binding CancelCommand}"/>
                        <Button Grid.Column="2" Content="Зберегти" Height="42"
                                Background="#4A7C59" CornerRadius="10" BorderThickness="0"
                                Foreground="White" FontWeight="SemiBold"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Command="{Binding SaveCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Panel>
    </Panel>
</UserControl>
