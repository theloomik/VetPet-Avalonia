<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MyGameApp.ViewModels"
             xmlns:models="using:MyGameApp.Models"
             x:Class="MyGameApp.Views.ProvidersView"
             x:DataType="vm:ProvidersViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="30,25">

        <TextBlock Grid.Row="0"
                   Text="Провайдери"
                   Foreground="White"
                   FontSize="26"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <TextBox Grid.Row="1"
                 Watermark="Пошук провайдера..."
                 Classes="DarkInput"
                 Height="42"
                 Text="{Binding SearchText}"
                 Margin="0,0,0,20"/>

        <Grid Grid.Row="2" ColumnDefinitions="200,20,*,60" Margin="10,0,10,8">
            <TextBlock Grid.Column="0" Text="ТЕЛЕФОН"          Classes="Header"/>
            <TextBlock Grid.Column="2" Text="НАЗВА / ПРЕДСТАВНИК" Classes="Header"/>
        </Grid>

        <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Providers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:Provider">
                        <StackPanel>
                            <Grid ColumnDefinitions="200,20,*,60"
                                  Height="55" Margin="10,0,10,0"
                                  VerticalAlignment="Center">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Phone}"
                                           Foreground="#E0E0E0"
                                           FontSize="15"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="1"
                                        Width="1" Background="White"
                                        Opacity="0.08"
                                        Margin="0,12"
                                        HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Name}"
                                           Foreground="#E0E0E0"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="3"
                                        Classes="ArrowBtn"
                                        Margin="0,0,5,0">
                                    <TextBlock Text="→" Foreground="#BBBBBB" FontSize="18"/>
                                </Button>
                            </Grid>
                            <Border Height="1" Background="White" Opacity="0.05"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</UserControl>
