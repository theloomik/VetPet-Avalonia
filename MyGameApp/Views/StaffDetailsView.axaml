<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MyGameApp.ViewModels"
             xmlns:models="using:MyGameApp.Models"
             x:Class="MyGameApp.Views.StaffDetailsView"
             x:DataType="vm:StaffDetailsViewModel">

    <Grid RowDefinitions="Auto,20,*" Margin="30,25">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*">
            <Button Grid.Column="0"
                    Width="40" Height="40"
                    CornerRadius="10"
                    BorderThickness="0"
                    Background="#3A3A3A"
                    Command="{Binding GoBackCommand}">
                <TextBlock Text="←" Foreground="White" FontSize="18" HorizontalAlignment="Center"/>
            </Button>
            <TextBlock Grid.Column="1"
                       Margin="16,0,0,0"
                       VerticalAlignment="Center"
                       Text="Профіль працівника"
                       Foreground="White"
                       FontSize="26"
                       FontWeight="Bold"/>
        </Grid>

        <Border Grid.Row="2" Background="#262626" CornerRadius="14" Padding="24">
            <StackPanel Spacing="14">
                <TextBlock Text="{Binding FullName}" Foreground="White" FontSize="24" FontWeight="SemiBold"/>

                <Grid ColumnDefinitions="100,10,100" IsVisible="{Binding !IsEditMode}">
                    <Button Grid.Column="0"
                            Content="Редагувати"
                            Height="40"
                            Background="#3A3A3A"
                            CornerRadius="10"
                            BorderThickness="0"
                            Foreground="White"
                            IsVisible="{Binding !IsArchived}"
                            Command="{Binding StartEditCommand}"/>
                    <Button Grid.Column="2"
                            Content="Видалити"
                            Height="40"
                            Background="#3A3A3A"
                            BorderBrush="#7C4A4A"
                            CornerRadius="10"
                            BorderThickness="1.5"
                            Foreground="White"
                            IsVisible="{Binding !IsArchived}"
                            Command="{Binding ArchiveStaffCommand}"/>
                </Grid>

                <TextBlock Text="Працівник архівований"
                           Foreground="#C68B8B"
                           IsVisible="{Binding IsArchived}"/>

                <TextBlock Text="{Binding LoadError}" Foreground="#FF6B6B"
                           IsVisible="{Binding LoadError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                <Grid IsVisible="{Binding !IsEditMode}"
                      ColumnDefinitions="180,*"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                      RowSpacing="10">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Телефон" Classes="Header"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Phone}" Foreground="#E0E0E0"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Посада" Classes="Header"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Position}" Foreground="#E0E0E0"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Зарплата" Classes="Header"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Salary}" Foreground="#E0E0E0"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Робочі дні" Classes="Header"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding WorkDays}" Foreground="#E0E0E0"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Години роботи" Classes="Header"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding WorkHours}" Foreground="#E0E0E0"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Створено" Classes="Header"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding CreatedAt}" Foreground="#E0E0E0"/>
                </Grid>

                <StackPanel IsVisible="{Binding IsEditMode}" Spacing="10">
                    <TextBox Watermark="Прізвище *" Classes="DarkInput" Text="{Binding EditLastName}" Height="40"/>
                    <TextBox Watermark="Ім'я *" Classes="DarkInput" Text="{Binding EditFirstName}" Height="40"/>
                    <TextBox Watermark="Телефон *" Classes="DarkInput" Text="{Binding EditPhone}" Height="40"/>

                    <ComboBox ItemsSource="{Binding PositionOptions}"
                              SelectedItem="{Binding SelectedPosition}"
                              Height="40"
                              Background="#3A3A3A"
                              BorderThickness="0"
                              CornerRadius="10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="models:StaffPosition">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding Position}" Foreground="White"/>
                                    <TextBlock Text="{Binding Salary, StringFormat='({0:0} ₴)'}" Foreground="#888888" FontSize="12"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBox Watermark="Робочі дні" Classes="DarkInput" Text="{Binding EditWorkDays}" Height="40"/>

                    <Grid ColumnDefinitions="*,10,*">
                        <TextBox Grid.Column="0" Watermark="Початок (HH:mm)" Classes="DarkInput" Text="{Binding EditStartTime}" Height="40"/>
                        <TextBox Grid.Column="2" Watermark="Кінець (HH:mm)" Classes="DarkInput" Text="{Binding EditEndTime}" Height="40"/>
                    </Grid>

                    <TextBlock Text="{Binding EditError}" Foreground="#FF6B6B"
                               IsVisible="{Binding EditError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                    <Grid ColumnDefinitions="*,10,*">
                        <Button Grid.Column="0"
                                Content="Скасувати"
                                Height="40"
                                Background="#3A3A3A"
                                CornerRadius="10"
                                BorderThickness="0"
                                Foreground="#CCCCCC"
                                Command="{Binding CancelEditCommand}"/>
                        <Button Grid.Column="2"
                                Content="Зберегти"
                                Height="40"
                                Background="#3A3A3A"
                                BorderBrush="#4A7C59"
                                CornerRadius="10"
                                BorderThickness="1.5"
                                Foreground="White"
                                Command="{Binding SaveEditCommand}"/>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
