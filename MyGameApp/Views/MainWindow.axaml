<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MyGameApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:dataflow="using:System.Threading.Tasks.Dataflow"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="MyGameApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="VetPet">


        <Grid Background="#ffffff" ColumnDefinitions="100, 100">
            <Button Grid.Column="0" Content="Button1"> </Button>
            <Button Grid.Column="1" Content="Button2"> </Button>
        </Grid>


</Window>
