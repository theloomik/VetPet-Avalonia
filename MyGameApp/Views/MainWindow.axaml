<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MyGameApp.ViewModels"
        xmlns:views="clr-namespace:MyGameApp.Views"
        x:Class="MyGameApp.Views.MainWindow"
        Title="MyGameApp">
    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>
    <Window.DataTemplates>
        <DataTemplate DataType="vm:ClientsViewModel">
            <views:ClientsView/>
        </DataTemplate>
        <DataTemplate DataType="vm:StaffViewModel">
            <views:StaffView/>
        </DataTemplate>
        <DataTemplate DataType="vm:AppointmentsViewModel">
            <views:AppointmentsView/>
        </DataTemplate>
        <DataTemplate DataType="vm:ProvidersViewModel">
            <views:ProvidersView/>
        </DataTemplate>
        <DataTemplate DataType="vm:StockViewModel">
            <views:StockView/>
        </DataTemplate>
    </Window.DataTemplates>
    <Grid ColumnDefinitions="260,*">
        <Border Background="#2B2B2B">
            <StackPanel Margin="15" Spacing="10">
                <Button Content="Клієнти"
                        Command="{Binding ChangeTabCommand}"
                        CommandParameter="0"/>
                <Button Content="Записи"
                        Command="{Binding ChangeTabCommand}"
                        CommandParameter="1"/>
                <Button Content="Працівники"
                        Command="{Binding ChangeTabCommand}"
                        CommandParameter="2"/>
                <Button Content="Провайдери"
                        Command="{Binding ChangeTabCommand}"
                        CommandParameter="3"/>
                <Button Content="Склад"
                        Command="{Binding ChangeTabCommand}"
                        CommandParameter="4"/>
            </StackPanel>
        </Border>
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentViewModel}"/>
    </Grid>
</Window>