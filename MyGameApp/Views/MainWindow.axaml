<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MyGameApp.ViewModels"
        xmlns:models="using:MyGameApp.Models"
        xmlns:views="clr-namespace:MyGameApp.Views"
        x:Class="MyGameApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="VetPet"
        Background="#1E1E1E"
        Width="1100" Height="680"
        MinWidth="900" MinHeight="500">

    <Window.Styles>
        <Style Selector="Button.MenuBtn">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.MenuBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#3A3A3A"/>
        </Style>
        <Style Selector="Button.MenuBtn.Active /template/ ContentPresenter">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#454545"/>
        </Style>

        <Style Selector="Border.Card">
            <Setter Property="Background" Value="#2B2B2B"/>
            <Setter Property="CornerRadius" Value="14"/>
        </Style>

        <Style Selector="TextBox.DarkInput">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
        <Style Selector="TextBox.DarkInput /template/ TextBlock#PART_Watermark">
            <Setter Property="Foreground" Value="#767676"/>
        </Style>

        <Style Selector="Button.ArrowBtn">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.ArrowBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#555555"/>
        </Style>

        <Style Selector="ToggleButton.WorkDayBtn">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="ToggleButton.WorkDayBtn /template/ ContentPresenter">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="ToggleButton.WorkDayBtn:checked">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="BorderBrush" Value="#4A7C59"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style Selector="ToggleButton.WorkDayBtn:checked /template/ ContentPresenter">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="BorderBrush" Value="#4A7C59"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

        <Style Selector="TextBlock.Header">
            <Setter Property="Foreground" Value="#757575"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="Button.RowBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Button.RowBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#333333"/>
        </Style>

        <Style Selector="Button.HeaderActionBtn">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="BorderBrush" Value="#4A6A7C"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Styles>

    <Window.DataTemplates>
        <DataTemplate DataType="vm:ClientsViewModel">
            <views:ClientsView/>
        </DataTemplate>
        <DataTemplate DataType="vm:StaffViewModel">
            <views:StaffView/>
        </DataTemplate>
        <DataTemplate DataType="vm:AppointmentsViewModel">
            <views:AppointmentsView/>
        </DataTemplate>
        <DataTemplate DataType="vm:ProvidersViewModel">
            <views:ProvidersView/>
        </DataTemplate>
        <DataTemplate DataType="vm:StockViewModel">
            <views:StockView/>
        </DataTemplate>
        <DataTemplate DataType="vm:ClientDetailsViewModel">
            <views:ClientDetailsView/>
        </DataTemplate>
        <DataTemplate DataType="vm:StaffDetailsViewModel">
            <views:StaffDetailsView/>
        </DataTemplate>
        <DataTemplate DataType="vm:ProviderDetailsViewModel">
            <views:ProviderDetailsView/>
        </DataTemplate>
    </Window.DataTemplates>

    <Panel>
        <Grid ColumnDefinitions="260,*" Margin="15"
              IsEnabled="{Binding !IsQuickAppointmentOpen}">

            <Border Grid.Column="0" Classes="Card" Margin="0,0,12,0">
                <StackPanel Spacing="6" Margin="12,20" Name="MenuPanel">
                    <TextBlock Text="VetPet"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <Button Classes="MenuBtn Active" Content="🐾  Клієнти" Tag="0" Click="OnMenuButtonClick"/>
                    <Button Classes="MenuBtn" Content="📅  Записи" Tag="1" Click="OnMenuButtonClick"/>
                    <Button Classes="MenuBtn" Content="👤  Працівники" Tag="2" Click="OnMenuButtonClick"/>
                    <Button Classes="MenuBtn" Content="🏭  Провайдери" Tag="3" Click="OnMenuButtonClick"/>
                    <Button Classes="MenuBtn" Content="💊  Склад" Tag="4" Click="OnMenuButtonClick"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Classes="Card">
                <Grid RowDefinitions="Auto,*">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="24,20,24,12">
                        <TextBlock Text="Робоча панель"
                                   Foreground="#A2A2A2"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Classes="HeaderActionBtn"
                                IsEnabled="{Binding !IsAnyRightModalOpen}"
                                Command="{Binding OpenQuickAppointmentCommand}">
                            <TextBlock Text="+ Швидкий запис" Foreground="White" FontWeight="SemiBold"/>
                        </Button>
                    </Grid>
                    <Border Grid.Row="0"
                            Background="#66000000"
                            IsVisible="{Binding IsChildModalOpen}"
                            ZIndex="5"/>

                    <Border Grid.Row="0" Height="1" Margin="24,62,24,0" Background="White" Opacity="0.06"/>
                    <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}"/>
                </Grid>
            </Border>
        </Grid>

        <Panel IsVisible="{Binding IsQuickAppointmentOpen}" ZIndex="100">
            <Border Background="#88000000"/>
            <Border Width="700"
                    MaxWidth="700"
                    MinWidth="560"
                    MaxHeight="620"
                    Padding="0"
                    Background="#2A2D33"
                    BorderBrush="#4A6A7C"
                    BorderThickness="1"
                    CornerRadius="14"
                    BoxShadow="0 10 24 0 #36000000"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    DataContext="{Binding QuickAppointmentForm}"
                    x:DataType="vm:QuickAppointmentViewModel">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="24,20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Швидкий запис на прийом"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,0,0,4"/>

                    <TextBlock Text="Телефон клієнта *" Classes="Header"/>
                    <TextBox Classes="DarkInput"
                             Watermark="Введіть телефон для пошуку"
                             Text="{Binding ClientPhone}"
                             Height="42"/>

                    <ComboBox ItemsSource="{Binding ClientMatches}"
                              SelectedItem="{Binding SelectedClient}"
                              IsVisible="{Binding !CreateNewClient}"
                              Height="42"
                              Background="#3A3A3A"
                              BorderThickness="0"
                              CornerRadius="10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="models:Client">
                                <TextBlock Foreground="White">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} {1} | {2}">
                                            <Binding Path="LastName"/>
                                            <Binding Path="FirstName"/>
                                            <Binding Path="Phone"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <CheckBox Content="Створити нового клієнта"
                              Foreground="#D0D0D0"
                              IsChecked="{Binding CreateNewClient}"/>

                    <Grid ColumnDefinitions="*,10,*" IsVisible="{Binding CreateNewClient}">
                        <TextBox Grid.Column="0" Classes="DarkInput"
                                 Watermark="Прізвище *"
                                 Text="{Binding ClientLastName}"
                                 Height="42"/>
                        <TextBox Grid.Column="2" Classes="DarkInput"
                                 Watermark="Ім'я *"
                                 Text="{Binding ClientFirstName}"
                                 Height="42"/>
                    </Grid>

                    <Border Height="1" Background="White" Opacity="0.08" Margin="0,2"/>

                    <TextBlock Text="Тварина *" Classes="Header"/>
                    <ComboBox ItemsSource="{Binding PetOptions}"
                              SelectedItem="{Binding SelectedPet}"
                              IsEnabled="{Binding CanSelectExistingPet}"
                              Height="42"
                              Background="#3A3A3A"
                              BorderThickness="0"
                              CornerRadius="10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="models:Pet">
                                <TextBlock Foreground="White">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} ({1})">
                                            <Binding Path="Name"/>
                                            <Binding Path="PetType.Species"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <CheckBox Content="Додати нову тварину"
                              Foreground="#D0D0D0"
                              IsChecked="{Binding CreateNewPet}"/>

                    <Grid ColumnDefinitions="*,10,*" IsVisible="{Binding CreateNewPet}">
                        <TextBox Grid.Column="0"
                                 Classes="DarkInput"
                                 Watermark="Кличка *"
                                 Text="{Binding NewPetName}"
                                 Height="42"/>
                        <ComboBox Grid.Column="2"
                                  ItemsSource="{Binding PetTypeOptions}"
                                  SelectedItem="{Binding SelectedPetType}"
                                  Height="42"
                                  Background="#3A3A3A"
                                  BorderThickness="0"
                                  CornerRadius="10">
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="models:PetType">
                                    <TextBlock Foreground="White">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} {1}">
                                                <Binding Path="Species"/>
                                                <Binding Path="Breed"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>

                    <ComboBox ItemsSource="{Binding PetGenderOptions}"
                              SelectedItem="{Binding SelectedPetGender}"
                              IsVisible="{Binding CreateNewPet}"
                              Height="42"
                              Background="#3A3A3A"
                              BorderThickness="0"
                              CornerRadius="10"/>

                    <TextBlock Text="Лікар *" Classes="Header"/>
                    <ComboBox ItemsSource="{Binding StaffOptions}"
                              SelectedItem="{Binding SelectedStaff}"
                              Height="42"
                              Background="#3A3A3A"
                              BorderThickness="0"
                              CornerRadius="10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="models:Staff">
                                <TextBlock Foreground="White">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} {1}">
                                            <Binding Path="LastName"/>
                                            <Binding Path="FirstName"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Grid ColumnDefinitions="*,10,*">
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="Дата та час *" Classes="Header"/>
                            <TextBox Classes="DarkInput"
                                     Text="{Binding DateText}"
                                     Height="42"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="6">
                            <TextBlock Text="Послуга" Classes="Header"/>
                            <ComboBox ItemsSource="{Binding ServiceOptions}"
                                      SelectedItem="{Binding SelectedService}"
                                      Height="42"
                                      Background="#3A3A3A"
                                      BorderThickness="0"
                                      CornerRadius="10">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="models:Service">
                                        <TextBlock Text="{Binding Name}" Foreground="White"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Статус" Classes="Header"/>
                    <ComboBox ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding SelectedStatus}"
                              Height="42"
                              Background="#3A3A3A"
                              BorderThickness="0"
                              CornerRadius="10"/>

                    <TextBlock Text="Примітка" Classes="Header"/>
                    <TextBox Classes="DarkInput"
                             Text="{Binding Description}"
                             Height="42"
                             Watermark="Короткий опис (необов'язково)"/>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#FF6B6B"
                               IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               HorizontalAlignment="Center"/>

                        <Grid ColumnDefinitions="*,10,*" Margin="0,8,0,0">
                            <Button Grid.Column="0"
                                    Content="Скасувати"
                                    Height="42"
                                    Background="#3A3A3A"
                                    CornerRadius="10"
                                    BorderThickness="0"
                                    Foreground="#C0C0C0"
                                    Command="{Binding CancelCommand}"/>
                            <Button Grid.Column="2"
                                    Content="Зберегти"
                                    Height="42"
                                    Background="#3A3A3A"
                                    BorderBrush="#4A7C59"
                                    CornerRadius="10"
                                    BorderThickness="1.5"
                                    Foreground="White"
                                    FontWeight="SemiBold"
                                    Command="{Binding SaveCommand}"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Panel>
    </Panel>
</Window>
