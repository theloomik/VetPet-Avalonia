<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MyGameApp.ViewModels"
             x:Class="MyGameApp.Views.StockView"
             x:DataType="vm:StockViewModel">

    <Grid RowDefinitions="Auto,*" Margin="25">

        <TextBox Watermark="Пошук препарату..."
                 Text="{Binding SearchText}"
                 Height="42"
                 Margin="0,0,0,20"/>

        <ItemsControl Grid.Row="1"
                      ItemsSource="{Binding Stocks}">

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12"
                            Margin="0,0,0,8"
                            Background="#2E2E2E"
                            CornerRadius="8">

                        <StackPanel>
                            <TextBlock Text="{Binding Medicine.Name}" />
                            <TextBlock Text="{Binding Quantity}"
                                       Opacity="0.7"/>
                        </StackPanel>

                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>

        </ItemsControl>

    </Grid>
</UserControl>
