<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MyGameApp.ViewModels"
             xmlns:models="using:MyGameApp.Models"
             x:Class="MyGameApp.Views.StockView"
             x:DataType="vm:StockViewModel"
             x:Name="Root">
    <Panel>
        <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="30,25"
              IsEnabled="{Binding !IsAnyModalOpen}">
            <TextBlock Grid.Row="0" Text="Склад"
                       Foreground="White" FontSize="26" FontWeight="Bold"
                       Margin="0,0,0,20"/>
            <Grid Grid.Row="1" ColumnDefinitions="*,10,Auto,10,Auto" Height="42" Margin="0,0,0,20">

                <TextBox Grid.Column="0" Watermark="Пошук за назвою"
                         Classes="DarkInput" Text="{Binding SearchText}"/>
                <Button Grid.Column="2" Width="60" Height="42"
                        Background="#3A3A3A" CornerRadius="10" BorderThickness="0"
                        Command="{Binding ToggleSortCommand}">
                    <TextBlock Text="{Binding SortLabel}" Foreground="White" FontWeight="Bold"/>
                </Button>
                <Button Grid.Column="4" Width="100" Height="42"
                        Background="#3A3A3A" CornerRadius="10" BorderThickness="0"
                        Command="{Binding AddStockCommand}">
                    <TextBlock Text="+ Новий" Foreground="White" FontWeight="SemiBold"/>
                </Button>
            </Grid>

            <Grid Grid.Row="2" ColumnDefinitions="150,10,150,10,75,*,110,10,60" Margin="10,0,10,8">
                <TextBlock Grid.Column="0" Text="НАЗВА ПРЕПАРАТУ" Classes="Header" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="ЦІНА" Classes="Header" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="КІЛЬКІСТЬ" Classes="Header" HorizontalAlignment="Center"/>
            </Grid>

            <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Stocks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:StockRow">
                            <StackPanel>
                                <Grid ColumnDefinitions="150,10,150,10,75,*,110,10,60" Height="55"
                                      Margin="10,0,10,0" VerticalAlignment="Center">

                                    <TextBlock Grid.Column="0" Text="{Binding MedicineName}"
                                               Foreground="#E0E0E0" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Width="1" Background="White"
                                            Opacity="0.08" Margin="0,12" HorizontalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{Binding Price}"
                                               Foreground="#E0E0E0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <Border Grid.Column="3" Width="1" Background="White"
                                            Opacity="0.08" Margin="0,12" HorizontalAlignment="Center" />
                                    <TextBlock Grid.Column="4" Text="{Binding Quantity}"
                                               Foreground="#A0A0A0" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                    <Button Grid.Column="6" Height="36"
                                            Background="#3A3A3A"
                                            CornerRadius="8"
                                            BorderThickness="0"
                                            Command="{Binding DataContext.OpenEditCommand, ElementName=Root}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="Редагувати" Foreground="White" FontSize="13"/>
                                    </Button>

                                    <Button Grid.Column="8" Classes="ArrowBtn" Margin="0,0,10,0"
                                            Command="{Binding DataContext.GoToProviderCommand, ElementName=Root}"
                                            CommandParameter="{Binding}"
                                            IsEnabled="{Binding HasProvider}">
                                        <TextBlock Text="→" Foreground="#FFFFFF" FontSize="18"/>
                                    </Button>

                                </Grid>
                                <Border Height="1" Background="White" Opacity="0.05"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Panel IsVisible="{Binding IsAddOpen}">
            <Border Background="#88000000"/>
            <Border Width="420" Padding="28"
                    Background="#2B2B2B" CornerRadius="14"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    DataContext="{Binding AddForm}"
                    x:DataType="vm:AddStockViewModel">
                <StackPanel Spacing="14">
                    <TextBlock Text="Новий препарат" FontSize="20" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBox Watermark="Назва препарату *" Classes="DarkInput"
                             Text="{Binding MedicineName}" Height="42"/>
                    <TextBox Watermark="Ціна продажу *" Classes="DarkInput"
                             Text="{Binding Price}" Height="42"/>
                    <TextBox Watermark="Кількість *" Classes="DarkInput"
                             Text="{Binding Quantity}" Height="42"/>

                    <StackPanel Spacing="6">
                        <TextBlock Text="ПРОВАЙДЕР" Classes="Header"/>
                        <ComboBox ItemsSource="{Binding Providers}"
                                  SelectedItem="{Binding SelectedProvider}"
                                  HorizontalAlignment="Stretch" Height="42"
                                  Background="#3A3A3A" BorderThickness="0" CornerRadius="10">
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="models:Provider">
                                    <TextBlock Text="{Binding Name}" Foreground="White"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF6B6B"
                               IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               FontSize="13" HorizontalAlignment="Center"/>
                    <Grid ColumnDefinitions="*,10,*" Margin="0,8,0,0">
                        <Button Grid.Column="0" Content="Скасувати" Height="42"
                                Background="#3A3A3A" CornerRadius="10" BorderThickness="0"
                                Foreground="#AAAAAA" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Command="{Binding CancelCommand}"/>
                        <Button Grid.Column="2" Content="Зберегти" Height="42"
                                Background="#3A3A3A" BorderBrush="#4A7C59" CornerRadius="10" BorderThickness="1.5"
                                Foreground="White" FontWeight="SemiBold"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Command="{Binding SaveCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Panel>

        <Panel IsVisible="{Binding IsEditOpen}">
            <Border Background="#88000000"/>
            <Border Width="420" Padding="28"
                    Background="#2B2B2B" CornerRadius="14"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    DataContext="{Binding EditForm}"
                    x:DataType="vm:EditStockItemViewModel">
                <StackPanel Spacing="14">
                    <TextBlock Text="Редагувати предмет" FontSize="20" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBox Watermark="Назва препарату *" Classes="DarkInput"
                             Text="{Binding MedicineName}" Height="42"/>
                    <TextBox Watermark="Ціна продажу *" Classes="DarkInput"
                             Text="{Binding Price}" Height="42"/>
                    <TextBox Watermark="Кількість *" Classes="DarkInput"
                             Text="{Binding Quantity}" Height="42"/>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF6B6B"
                               IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               FontSize="13" HorizontalAlignment="Center"/>
                    <Grid ColumnDefinitions="*,10,*" Margin="0,8,0,0">
                        <Button Grid.Column="0" Content="Скасувати" Height="42"
                                Background="#3A3A3A" CornerRadius="10" BorderThickness="0"
                                Foreground="#AAAAAA" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Command="{Binding CancelCommand}"/>
                        <Button Grid.Column="2" Content="Зберегти" Height="42"
                                Background="#3A3A3A" BorderBrush="#4A7C59" CornerRadius="10" BorderThickness="1.5"
                                Foreground="White" FontWeight="SemiBold"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Command="{Binding SaveCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Panel>
    </Panel>
</UserControl>
