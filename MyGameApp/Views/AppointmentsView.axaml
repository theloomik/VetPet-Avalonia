<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MyGameApp.ViewModels"
             x:Class="MyGameApp.Views.AppointmentsView"
             x:DataType="vm:AppointmentsViewModel"
             x:Name="Root">

    <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="30,25">
        <TextBlock Grid.Row="0" Text="Записи"
                   Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,0,0,20"/>

        <Grid Grid.Row="1" ColumnDefinitions="*,10,Auto,10,Auto" Height="42" Margin="0,0,0,20">
            <TextBox Grid.Column="0" Watermark="Пошук за номером телефону"
                     Classes="DarkInput" Text="{Binding SearchText}"/>
            <Button Grid.Column="2" Width="75" Height="42"
                    Background="#3A3A3A" CornerRadius="10" BorderThickness="0"
                    Command="{Binding ToggleSortCommand}">
                <TextBlock Text="{Binding SortLabel}" Foreground="White" FontWeight="Bold"/>
            </Button>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="150,10,150,10,150,10,140,*,60" Margin="10,0,10,8">
            <TextBlock Grid.Column="0" Text="ДАТА ТА ЧАС" Classes="Header" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="ТЕЛЕФОН КЛІЄНТА" Classes="Header" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="4" Text="КЛИЧКА" Classes="Header" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="6" Text="СТАТУС" Classes="Header" HorizontalAlignment="Center"/>
        </Grid>

        <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Appointments}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:AppointmentListRow">
                        <StackPanel>
                            <Grid ColumnDefinitions="150,10,150,10,150,10,140,*,60"
                                  Height="55" Margin="10,0,10,0"
                                  VerticalAlignment="Center">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Source.Date, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                                           Foreground="#E0E0E0"
                                           VerticalAlignment="Center" HorizontalAlignment="Center" />
                                <Border Grid.Column="1" Width="1" Background="White"
                                        Opacity="0.08" Margin="0,12" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding ClientPhone}"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center" HorizontalAlignment="Center" />
                                <Border Grid.Column="3" Width="1" Background="White"
                                        Opacity="0.08" Margin="0,12" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="4"
                                           Text="{Binding PetName}"
                                           Foreground="#A0A0A0"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <Border Grid.Column="6"
                                        BorderBrush="{Binding StatusColor}"
                                        BorderThickness="1.5"
                                        CornerRadius="8"
                                        Height="30"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Padding="10,0">
                                    <TextBlock Text="{Binding Status}"
                                               Foreground="{Binding StatusColor}"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <Button Grid.Column="8"
                                        Classes="ArrowBtn"
                                        Margin="0,0,5,0"
                                        Command="{Binding DataContext.GoToClientDetailsCommand, ElementName=Root}"
                                        CommandParameter="{Binding}">
                                    <TextBlock Text="→" Foreground="#FFFFFF" FontSize="18" />
                                </Button>
                            </Grid>
                            <Border Height="1" Background="White" Opacity="0.05"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</UserControl>
