<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MyGameApp.ViewModels"
             x:Class="MyGameApp.Views.AppointmentsView"
             x:DataType="vm:AppointmentsViewModel"
             x:Name="Root">

    <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="30,25">
        <TextBlock Grid.Row="0" Text="Записи"
                   Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,0,0,20"/>

        <Grid Grid.Row="1" ColumnDefinitions="*,10,Auto" Height="42" Margin="0,0,0,20">
            <TextBox Grid.Column="0" Watermark="Пошук (телефон, ПІБ клієнта, кличка)"
                     Classes="DarkInput" Text="{Binding SearchText}"/>
            <Button Grid.Column="2" Width="86" Height="42"
                    Background="#3A3A3A" CornerRadius="10" BorderThickness="0"
                    Command="{Binding ToggleSortCommand}">
                <TextBlock Text="{Binding SortLabel}" Foreground="White" FontWeight="Bold"/>
            </Button>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="170,10,170,10,130,10,130,*" Margin="10,0,10,8">
            <TextBlock Grid.Column="0" Text="ДАТА ТА ЧАС" Classes="Header" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="КЛІЄНТ" Classes="Header" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="4" Text="КЛИЧКА" Classes="Header" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="6" Text="СТАТУС" Classes="Header" HorizontalAlignment="Center"/>
        </Grid>

        <TextBlock Grid.Row="3"
                   Text="Записів за фільтром не знайдено"
                   Foreground="#999999"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   IsVisible="{Binding !HasAppointments}"/>

        <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Disabled" IsVisible="{Binding HasAppointments}">
            <ItemsControl ItemsSource="{Binding AppointmentGroups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:AppointmentGroupRow">
                        <StackPanel Margin="0,0,0,16">
                            <Border Background="#323232" CornerRadius="10" Padding="12,8" Margin="10,0,10,8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Width="10" Height="10" CornerRadius="5" Background="{Binding MarkerColor}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:AppointmentListRow">
                                        <StackPanel>
                                            <Button Classes="RowBtn"
                                                    Height="55"
                                                    Margin="10,0,10,0"
                                                    Command="{Binding DataContext.GoToClientDetailsCommand, ElementName=Root}"
                                                    CommandParameter="{Binding}">
                                                <Grid ColumnDefinitions="170,10,170,10,130,10,130,*"
                                                      VerticalAlignment="Center">
                                                    <Border Grid.Column="0"
                                                            BorderThickness="3,0,0,0"
                                                            BorderBrush="{Binding DateMarkerColor}"
                                                            Background="#2F2F2F"
                                                            CornerRadius="8"
                                                            Padding="10,4"
                                                            HorizontalAlignment="Stretch">
                                                        <TextBlock Text="{Binding Source.Date, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                                                                   Foreground="#E0E0E0"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center"/>
                                                    </Border>

                                                    <Border Grid.Column="1" Width="1" Background="White"
                                                            Opacity="0.08" Margin="0,12" HorizontalAlignment="Center"/>

                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="1">
                                                        <TextBlock Text="{Binding ClientFullName}" Foreground="#E0E0E0" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding ClientPhone}" Foreground="#9A9A9A" FontSize="12"/>
                                                    </StackPanel>

                                                    <Border Grid.Column="3" Width="1" Background="White"
                                                            Opacity="0.08" Margin="0,12" HorizontalAlignment="Center"/>

                                                    <TextBlock Grid.Column="4"
                                                               Text="{Binding PetName}"
                                                               Foreground="#CFCFCF"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"/>

                                                    <Border Grid.Column="6"
                                                            BorderBrush="{Binding StatusColor}"
                                                            BorderThickness="1.5"
                                                            CornerRadius="8"
                                                            Height="30"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Padding="10,0">
                                                        <TextBlock Text="{Binding Status}"
                                                                   Foreground="{Binding StatusColor}"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>

                                                    <TextBlock Grid.Column="7"
                                                               Text="→"
                                                               Foreground="#8E8E8E"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,10,0"
                                                               FontSize="18"/>
                                                </Grid>
                                            </Button>
                                            <Border Height="1" Background="White" Opacity="0.05"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</UserControl>
