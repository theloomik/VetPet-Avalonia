<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MyGameApp.ViewModels"
             xmlns:models="using:MyGameApp.Models"
             x:Class="MyGameApp.Views.AppointmentsView"
             x:DataType="vm:AppointmentsViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="30,25">

        <TextBlock Grid.Row="0"
                   Text="Записи"
                   Foreground="White"
                   FontSize="26"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <TextBox Grid.Row="1"
                 Watermark="Пошук по телефону клієнта..."
                 Classes="DarkInput"
                 Height="42"
                 Text="{Binding SearchText}"
                 Margin="0,0,0,20"/>

        <Grid Grid.Row="2" ColumnDefinitions="170,180,*,60" Margin="10,0,10,8">
            <TextBlock Grid.Column="0" Text="ДАТА ТА ЧАС"      Classes="Header"/>
            <TextBlock Grid.Column="1" Text="ТЕЛЕФОН КЛІЄНТА"  Classes="Header"/>
            <TextBlock Grid.Column="2" Text="ТВАРИНА"          Classes="Header"/>
        </Grid>

        <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Appointments}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:Appointment">
                        <StackPanel>
                            <Grid ColumnDefinitions="170,180,*,60"
                                  Height="55" Margin="10,0,10,0"
                                  VerticalAlignment="Center">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Date, StringFormat='{}{0:dd.MM HH:mm}'}"
                                           Foreground="#E0E0E0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Client.Phone}"
                                           Foreground="#CCCCCC"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Pet.Name}"
                                           Foreground="#A0A0A0"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="3"
                                        Classes="ArrowBtn"
                                        Margin="0,0,5,0">
                                    <TextBlock Text="→" Foreground="#BBBBBB" FontSize="18"/>
                                </Button>
                            </Grid>
                            <Border Height="1" Background="White" Opacity="0.05"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</UserControl>
