<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MyGameApp.ViewModels"
             xmlns:models="using:MyGameApp.Models"
             x:Class="MyGameApp.Views.StaffView"
             x:DataType="vm:StaffViewModel"
             x:Name="Root">
    <Panel>
        <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="30,25"
              IsEnabled="{Binding !IsAddOpen}">
            <TextBlock Grid.Row="0" Text="Працівники"
                       Foreground="White" FontSize="26" FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <Grid Grid.Row="1" ColumnDefinitions="*,10,Auto,10,Auto" Height="42" Margin="0,0,0,20">
                <TextBox Grid.Column="0" Watermark="Пошук (телефон, ім'я, прізвище)"
                         Classes="DarkInput" Text="{Binding SearchText}"/>
                <Button Grid.Column="2" Width="60" Height="42"
                        Background="#3A3A3A" CornerRadius="10" BorderThickness="0"
                        Command="{Binding ToggleSortCommand}">
                    <TextBlock Text="{Binding SortLabel}" Foreground="White" FontWeight="Bold"/>
                </Button>
                <Button Grid.Column="4" Width="100" Height="42"
                        Background="#3A3A3A" CornerRadius="10" BorderThickness="0"
                        Command="{Binding AddStaffCommand}">
                    <TextBlock Text="+ Новий" Foreground="White" FontWeight="SemiBold"/>
                </Button>
            </Grid>

            <Grid Grid.Row="2" ColumnDefinitions="150,20,200,*,60" Margin="10,0,10,8">
                <TextBlock Grid.Column="0" Text="ТЕЛЕФОН" Classes="Header" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="ПРІЗВИЩЕ ТА ІМ'Я" Classes="Header" HorizontalAlignment="Center"/>
            </Grid>

            <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding StaffMembers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="models:Staff">
                            <StackPanel>
                                <Button Classes="RowBtn"
                                        Height="55"
                                        Margin="10,0,10,0"
                                        Command="{Binding DataContext.GoToDetailsCommand, ElementName=Root}"
                                        CommandParameter="{Binding}">
                                    <Grid ColumnDefinitions="150,20,35,200,*,60" VerticalAlignment="Center">
                                        <TextBlock Grid.Column="0" Text="{Binding Phone}"
                                                   Foreground="#E0E0E0" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <Border Grid.Column="1" Width="1" Background="White"
                                                Opacity="0.08" Margin="0,12" HorizontalAlignment="Center"/>
                                        <StackPanel Grid.Column="3" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="{Binding LastName}" Foreground="#FFFFFF"
                                                       FontSize="15" FontWeight="Medium"/>
                                            <TextBlock Text="{Binding FirstName}" Foreground="#A3A3A3" FontSize="13"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="5"
                                                   Text="→"
                                                   Foreground="#8E8E8E"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   FontSize="18"/>
                                    </Grid>
                                </Button>
                                <Border Height="1" Background="White" Opacity="0.05"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Модальний оверлей -->
        <Panel IsVisible="{Binding IsAddOpen}">
            <Border Background="#88000000"/>

            <Border Width="460" Padding="28"
                    Background="#2B2B2B" CornerRadius="14"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    DataContext="{Binding AddForm}"
                    x:DataType="vm:AddStaffViewModel">
                <StackPanel Spacing="14">

                    <TextBlock Text="Новий працівник" FontSize="20" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,4"/>

                    <!-- Основні поля -->
                    <TextBox Watermark="Прізвище *" Classes="DarkInput" Text="{Binding LastName}" Height="42"/>
                    <TextBox Watermark="Ім'я *" Classes="DarkInput" Text="{Binding FirstName}" Height="42"/>
                    <TextBox Watermark="Номер телефону *" Classes="DarkInput" Text="{Binding Phone}" Height="42"/>

                    <!-- Посада -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="ПОСАДА *" Classes="Header"/>

                        <!-- Вибір існуючої посади -->
                        <Grid ColumnDefinitions="*,8,Auto" IsVisible="{Binding !IsAddingPosition}">
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding Positions}"
                                      SelectedItem="{Binding SelectedPosition}"
                                      HorizontalAlignment="Stretch" Height="42"
                                      Background="#3A3A3A" BorderThickness="0" CornerRadius="10">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="models:StaffPosition">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Position}" Foreground="White"/>
                                            <TextBlock Text="{Binding Salary, StringFormat='({0:0} ₴)'}"
                                                       Foreground="#888888" FontSize="12"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Grid.Column="2" Width="42" Height="42"
                                    Background="#3A3A3A" CornerRadius="10" BorderThickness="0"
                                    ToolTip.Tip="Додати нову посаду"
                                    Command="{Binding ShowAddPositionCommand}">
                                <TextBlock Text="+" Foreground="White" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Margin="0,-2,0,0"/>
                            </Button>
                        </Grid>

                        <!-- Inline форма нової посади -->
                        <Border IsVisible="{Binding IsAddingPosition}"
                                Background="#333333" CornerRadius="10" Padding="14">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Нова посада" Foreground="#AAAAAA"
                                           FontSize="13" FontWeight="SemiBold"/>
                                <TextBox Watermark="Назва посади *" Classes="DarkInput"
                                         Text="{Binding NewPositionName}" Height="38"/>
                                <TextBox Watermark="Зарплата (грн) *" Classes="DarkInput"
                                         Text="{Binding NewPositionSalary}" Height="38"/>
                                <TextBlock Text="{Binding PositionError}" Foreground="#FF6B6B"
                                           IsVisible="{Binding PositionError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                           FontSize="12"/>
                                <Grid ColumnDefinitions="*,8,*">
                                    <Button Grid.Column="0" Content="Скасувати" Height="36"
                                            Background="#444444" CornerRadius="8" BorderThickness="0"
                                            Foreground="#AAAAAA" HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Command="{Binding CancelAddPositionCommand}"/>
                                    <Button Grid.Column="2" Content="Додати" Height="36"
                                            Background="#3A3A3A" BorderBrush="#4A6FA5" CornerRadius="8" BorderThickness="1.5"
                                            Foreground="White" FontWeight="SemiBold"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Command="{Binding SavePositionCommand}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="РОБОЧІ ДНІ" Classes="Header"/>
                        <WrapPanel>
                            <Grid ColumnDefinitions="58,58,58,58,58,58,58" Margin="5,0,5,0">
                                <ToggleButton Grid.Column="0" Width="48" Height="36" CornerRadius="8" Classes="WorkDayBtn"
                                            Content="Пн" IsChecked="{Binding DayMon}"
                                            FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <ToggleButton Grid.Column="1" Width="48" Height="36" CornerRadius="8" Classes="WorkDayBtn"
                                            Content="Вт" IsChecked="{Binding DayTue}"
                                            FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <ToggleButton Grid.Column="2" Width="48" Height="36" CornerRadius="8" Classes="WorkDayBtn"
                                            Content="Ср" IsChecked="{Binding DayWed}"
                                            FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <ToggleButton Grid.Column="3" Width="48" Height="36" CornerRadius="8" Classes="WorkDayBtn"
                                            Content="Чт" IsChecked="{Binding DayThu}"
                                            FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <ToggleButton Grid.Column="4" Width="48" Height="36" CornerRadius="8" Classes="WorkDayBtn"
                                            Content="Пт" IsChecked="{Binding DayFri}"
                                            FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <ToggleButton Grid.Column="5" Width="48" Height="36" CornerRadius="8" Classes="WorkDayBtn"
                                            Content="Сб" IsChecked="{Binding DaySat}"
                                            FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <ToggleButton Grid.Column="6" Width="48" Height="36" CornerRadius="8" Classes="WorkDayBtn"
                                            Content="Нд" IsChecked="{Binding DaySun}"
                                            FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </Grid>
                        </WrapPanel>
                    </StackPanel>

                    <!-- Графік - години -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="ГОДИНИ РОБОТИ" Classes="Header"/>
                        <Grid ColumnDefinitions="*,16,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Початок" Foreground="#666666" FontSize="11"/>
                                <TextBox Classes="DarkInput" Text="{Binding StartTime}"
                                         Height="42" TextAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="—" Foreground="#555555"
                                       VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                       Margin="0,0,0,10" FontSize="18"/>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Кінець" Foreground="#666666" FontSize="11"/>
                                <TextBox Classes="DarkInput" Text="{Binding EndTime}"
                                         Height="42" TextAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Помилка -->
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF6B6B"
                               IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               FontSize="13" HorizontalAlignment="Center"/>

                    <!-- Кнопки -->
                    <Grid ColumnDefinitions="*,10,*" Margin="0,4,0,0">
                        <Button Grid.Column="0" Content="Скасувати" Height="42"
                                Background="#3A3A3A" CornerRadius="10" BorderThickness="0"
                                Foreground="#AAAAAA" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Command="{Binding CancelCommand}"/>
                        <Button Grid.Column="2" Content="Зберегти" Height="42"
                                Background="#3A3A3A" BorderBrush="#4A7C59" CornerRadius="10" BorderThickness="1.5"
                                Foreground="White" FontWeight="SemiBold"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Command="{Binding SaveCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Panel>
    </Panel>
</UserControl>
