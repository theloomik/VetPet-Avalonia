<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MyGameApp.ViewModels"
             xmlns:models="using:MyGameApp.Models"
             x:Class="MyGameApp.Views.ClientDetailsView"
             x:DataType="vm:ClientDetailsViewModel">

    <UserControl.Resources>
        <vm:EqualityToBoolConverter x:Key="IsTab0" Expected="0"/>
        <vm:EqualityToBoolConverter x:Key="IsTab1" Expected="1"/>
        <vm:EqualityToBoolConverter x:Key="IsTab2" Expected="2"/>
        <vm:CountToBoolConverter x:Key="HasItems"/>
    </UserControl.Resources>

    <Panel>
        <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="30,25"
              IsEnabled="{Binding !IsAddPetOpen}">

            <Grid Grid.Row="0" ColumnDefinitions="42,*,Auto" Margin="0,0,0,22">
                <Button Grid.Column="0" Width="42" Height="42"
                        Background="#3A3A3A" CornerRadius="10"
                        BorderThickness="0"
                        Command="{Binding GoBackCommand}">
                    <TextBlock Text="←" Foreground="White" FontSize="18"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock FontSize="22" FontWeight="Bold" Foreground="White">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} {1}">
                                <Binding Path="SelectedClient.LastName"/>
                                <Binding Path="SelectedClient.FirstName"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <TextBlock Text="{Binding SelectedClient.Phone}" Foreground="#888888" FontSize="13"/>
                        <TextBlock Text="{Binding SelectedClient.Email}" Foreground="#888888" FontSize="13"
                                   IsVisible="{Binding SelectedClient.Email, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <Button Height="42" Padding="18,0"
                            Background="#4A7C59" CornerRadius="10"
                            BorderThickness="0"
                            Command="{Binding OpenAddPetCommand}">
                        <TextBlock Text="+ Тварина" Foreground="White" FontWeight="SemiBold"/>
                    </Button>
                    <Button Height="42" Padding="18,0"
                            Background="#3A3A3A" CornerRadius="10"
                            BorderThickness="0"
                            Command="{Binding StartEditCommand}">
                        <TextBlock Text="✏ Редагувати" Foreground="White" FontWeight="SemiBold"/>
                    </Button>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" Margin="0,0,0,16">
                <Button Height="38" Padding="20,0" CornerRadius="10"
                        Command="{Binding SetTabCommand}" CommandParameter="0"
                        Background="{Binding ActiveTab, Converter={StaticResource IsTab0}, ConverterParameter=bg}">
                    <TextBlock Text="🐾 Тварини" FontWeight="SemiBold"
                               Foreground="{Binding ActiveTab, Converter={StaticResource IsTab0}, ConverterParameter=fg}"/>
                </Button>
                <Button Height="38" Padding="20,0" CornerRadius="10"
                        Command="{Binding SetTabCommand}" CommandParameter="1"
                        Background="{Binding ActiveTab, Converter={StaticResource IsTab1}, ConverterParameter=bg}">
                    <TextBlock Text="📅 Записи" FontWeight="SemiBold"
                               Foreground="{Binding ActiveTab, Converter={StaticResource IsTab1}, ConverterParameter=fg}"/>
                </Button>
                <Button Height="38" Padding="20,0" CornerRadius="10"
                        Command="{Binding SetTabCommand}" CommandParameter="2"
                        Background="{Binding ActiveTab, Converter={StaticResource IsTab2}, ConverterParameter=bg}">
                    <TextBlock Text="💳 Рахунки" FontWeight="SemiBold"
                               Foreground="{Binding ActiveTab, Converter={StaticResource IsTab2}, ConverterParameter=fg}"/>
                </Button>
            </StackPanel>

            <Border Grid.Row="2" Height="1" Background="White" Opacity="0.07" Margin="0,0,0,14"/>

            <Panel Grid.Row="3">
                <Grid IsVisible="{Binding ActiveTab, Converter={StaticResource IsTab0}}">
                    <TextBlock Text="У клієнта ще немає тварин"
                               Foreground="#888888" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsVisible="{Binding Pets.Count, Converter={StaticResource HasItems}, ConverterParameter=invert}"/>
                    <ScrollViewer IsVisible="{Binding Pets.Count, Converter={StaticResource HasItems}}">
                        <ItemsControl ItemsSource="{Binding Pets}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="models:Pet">
                                    <Border Padding="10" BorderBrush="White" BorderThickness="0,0,0,1" Opacity="0.8">
                                        <Grid ColumnDefinitions="*,150,130">
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Name}" Foreground="White" FontSize="15" FontWeight="Medium"/>
                                                <TextBlock Text="{Binding Gender}" Foreground="#888888" FontSize="12"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding PetType.Species}" Foreground="#AAAAAA" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding BirthDate, StringFormat='{}{0:dd.MM.yyyy}'}" Foreground="#AAAAAA" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <Grid IsVisible="{Binding ActiveTab, Converter={StaticResource IsTab1}}">
                    <TextBlock Text="У клієнта ще немає записів"
                               Foreground="#888888" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsVisible="{Binding Appointments.Count, Converter={StaticResource HasItems}, ConverterParameter=invert}"/>
                    <ScrollViewer IsVisible="{Binding Appointments.Count, Converter={StaticResource HasItems}}">
                        <ItemsControl ItemsSource="{Binding Appointments}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:AppointmentRow">
                                    <Border Padding="12" BorderBrush="White" BorderThickness="0,0,0,1" Opacity="0.8">
                                        <Grid ColumnDefinitions="170,*,220,130">
                                            <TextBlock Grid.Column="0" Text="{Binding Date}" Foreground="#B0B0B0" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding ServiceName}" Foreground="White" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding PetName}" Foreground="#909090" FontSize="12"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding StaffName}" Foreground="#B0B0B0" VerticalAlignment="Center"/>
                                            <Border Grid.Column="3" Background="{Binding StatusColor}" CornerRadius="8" Height="28" VerticalAlignment="Center" HorizontalAlignment="Right" Padding="10,0">
                                                <TextBlock Text="{Binding Status}" Foreground="White" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <Grid IsVisible="{Binding ActiveTab, Converter={StaticResource IsTab2}}">
                    <TextBlock Text="У клієнта ще немає рахунків"
                               Foreground="#888888" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsVisible="{Binding Bills.Count, Converter={StaticResource HasItems}, ConverterParameter=invert}"/>
                    <ScrollViewer IsVisible="{Binding Bills.Count, Converter={StaticResource HasItems}}">
                        <ItemsControl ItemsSource="{Binding Bills}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:BillRow">
                                    <Border Padding="12" BorderBrush="White" BorderThickness="0,0,0,1" Opacity="0.8">
                                        <Grid ColumnDefinitions="170,*,160,130">
                                            <TextBlock Grid.Column="0" Text="{Binding Date}" Foreground="#B0B0B0" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Amount}" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Paid}" Foreground="#B0B0B0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            <Border Grid.Column="3" Background="{Binding PaidColor}" CornerRadius="8" Height="28" VerticalAlignment="Center" HorizontalAlignment="Right" Padding="10,0">
                                                <TextBlock Text="{Binding Source.PaymentMethod}" Foreground="White" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Panel>
        </Grid>

        <Panel IsVisible="{Binding IsAddPetOpen}">
            <Border Background="#88000000"/>
            <Border Width="420" Padding="28"
                    Background="#2B2B2B" CornerRadius="14"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    DataContext="{Binding AddPetForm}"
                    x:DataType="vm:AddPetViewModel">
                <StackPanel Spacing="14">
                    <TextBlock Text="Нова тварина" FontSize="20" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBox Watermark="Кличка *" Classes="DarkInput" Text="{Binding Name}" Height="42"/>
                    <TextBox Watermark="Дата народження (рррр-мм-дд)" Classes="DarkInput" Text="{Binding BirthDate}" Height="42"/>
                    <ComboBox ItemsSource="{Binding PetTypes}" SelectedItem="{Binding SelectedPetType}" Height="42"/>
                    <TextBox Watermark="Стать" Classes="DarkInput" Text="{Binding Gender}" Height="42"/>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF6B6B"
                               IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               FontSize="13" HorizontalAlignment="Center"/>
                    <Grid ColumnDefinitions="*,10,*" Margin="0,8,0,0">
                        <Button Grid.Column="0" Content="Скасувати" Height="42"
                                Background="#3A3A3A" CornerRadius="10" BorderThickness="0"
                                Foreground="#AAAAAA" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Command="{Binding CancelCommand}"/>
                        <Button Grid.Column="2" Content="Зберегти" Height="42"
                                Background="#4A7C59" CornerRadius="10" BorderThickness="0"
                                Foreground="White" FontWeight="SemiBold"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Command="{Binding SaveCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Panel>

        <Panel IsVisible="{Binding IsEditMode}">
            <Border Background="#88000000"/>
            <Border Width="460" Padding="28"
                    Background="#2B2B2B" CornerRadius="14"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="14">
                    <TextBlock Text="Редагувати клієнта" FontSize="20" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBox Watermark="Прізвище *" Classes="DarkInput" Text="{Binding EditLastName}" Height="42"/>
                    <TextBox Watermark="Ім'я *" Classes="DarkInput" Text="{Binding EditFirstName}" Height="42"/>
                    <TextBox Watermark="Телефон *" Classes="DarkInput" Text="{Binding EditPhone}" Height="42"/>
                    <TextBox Watermark="Email" Classes="DarkInput" Text="{Binding EditEmail}" Height="42"/>
                    <TextBlock Text="{Binding EditError}" Foreground="#FF6B6B"
                               IsVisible="{Binding EditError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               FontSize="13" HorizontalAlignment="Center"/>
                    <Grid ColumnDefinitions="*,10,*" Margin="0,8,0,0">
                        <Button Grid.Column="0" Content="Скасувати" Height="42"
                                Background="#3A3A3A" CornerRadius="10" BorderThickness="0"
                                Foreground="#AAAAAA" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Command="{Binding CancelEditCommand}"/>
                        <Button Grid.Column="2" Content="Зберегти" Height="42"
                                Background="#4A7C59" CornerRadius="10" BorderThickness="0"
                                Foreground="White" FontWeight="SemiBold"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Command="{Binding SaveEditCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Panel>
    </Panel>
</UserControl>
