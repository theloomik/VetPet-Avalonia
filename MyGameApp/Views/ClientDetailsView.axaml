<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MyGameApp.ViewModels"
             xmlns:models="using:MyGameApp.Models"
             x:Class="MyGameApp.Views.ClientDetailsView"
             x:DataType="vm:ClientDetailsViewModel">

    <UserControl.Resources>
        <vm:CountToBoolConverter x:Key="HasItems"/>
    </UserControl.Resources>

    <Panel>
        <Grid RowDefinitions="Auto,*" Margin="30,25" IsEnabled="{Binding !IsAnyModalOpen}">
            <Grid Grid.Row="0" RowDefinitions="Auto,Auto" Margin="0,0,0,14">
                <Grid Grid.Row="0" ColumnDefinitions="42,*,Auto" Margin="0,0,0,18">
                    <Button Grid.Column="0" Width="42" Height="42"
                            Background="#3A3A3A" CornerRadius="10" BorderThickness="0"
                            Command="{Binding GoBackCommand}">
                        <TextBlock Text="←" Foreground="White" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>

                    <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                        <TextBlock FontSize="22" FontWeight="Bold" Foreground="White">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} {1}">
                                    <Binding Path="SelectedClient.LastName"/>
                                    <Binding Path="SelectedClient.FirstName"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" Spacing="14">
                            <TextBlock Text="{Binding SelectedClient.Phone}" Foreground="#888888" FontSize="13"/>
                            <TextBlock Text="{Binding SelectedClient.Email}" Foreground="#888888" FontSize="13"
                                       IsVisible="{Binding SelectedClient.Email, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                        <Button Height="42" Padding="18,0" Background="#4A7C59" CornerRadius="10" BorderThickness="0" Command="{Binding OpenAddPetCommand}">
                            <TextBlock Text="+ Тварина" Foreground="White" FontWeight="SemiBold"/>
                        </Button>
                        <Button Height="42" Padding="18,0" Background="#4A6A7C" CornerRadius="10" BorderThickness="0" Command="{Binding OpenAddAppointmentCommand}">
                            <TextBlock Text="+ Запис" Foreground="White" FontWeight="SemiBold"/>
                        </Button>
                        <Button Height="42" Padding="18,0" Background="#7C6E4A" CornerRadius="10" BorderThickness="0" Command="{Binding OpenAddBillCommand}">
                            <TextBlock Text="+ Рахунок" Foreground="White" FontWeight="SemiBold"/>
                        </Button>
                        <Button Height="42" Padding="18,0" Background="#3A3A3A" CornerRadius="10" BorderThickness="0" Command="{Binding StartEditCommand}">
                            <TextBlock Text="Редагувати" Foreground="White" FontWeight="SemiBold"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Height="1" Background="White" Opacity="0.07"/>
            </Grid>

            <TabControl Grid.Row="1" SelectedIndex="{Binding ActiveTab}">
                <TabItem Header="Тварини">
                    <Grid Margin="0,10,0,0">
                        <TextBlock Text="No animals yet" Foreground="#888888" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   IsVisible="{Binding Pets.Count, Converter={StaticResource HasItems}, ConverterParameter=invert}"/>
                        <ScrollViewer IsVisible="{Binding Pets.Count, Converter={StaticResource HasItems}}">
                            <ItemsControl ItemsSource="{Binding Pets}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="models:Pet">
                                        <Border Padding="10" BorderBrush="White" BorderThickness="0,0,0,1" Opacity="0.8">
                                            <Grid ColumnDefinitions="200,250,130">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="15" FontWeight="Medium" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Gender}" Foreground="#888888" FontSize="12" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding PetType.Species}" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding PetType.Breed}" Foreground="#888888" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="3" Text="{Binding BirthDate, StringFormat='{}{0:dd.MM.yyyy}'}" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <TabItem Header="Записи">
                    <Grid Margin="0,10,0,0">
                        <TextBlock Text="У клієнта немає записів" Foreground="#888888" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   IsVisible="{Binding Appointments.Count, Converter={StaticResource HasItems}, ConverterParameter=invert}"/>
                        <ScrollViewer IsVisible="{Binding Appointments.Count, Converter={StaticResource HasItems}}">
                            <ItemsControl ItemsSource="{Binding Appointments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:AppointmentRow">
                                        <Border Padding="12" BorderBrush="White" BorderThickness="0,0,0,1" Opacity="0.8">
                                            <Grid>
                                                    <Grid ColumnDefinitions="170,*,220,130">
                                                        <TextBlock Grid.Column="0" Text="{Binding Date}" Foreground="#B0B0B0" VerticalAlignment="Center"/>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding ServiceName}" Foreground="White" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding PetName}" Foreground="#909090" FontSize="12"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" Text="{Binding StaffName}" Foreground="#B0B0B0" VerticalAlignment="Center"/>
                                                        <Border Grid.Column="3" Background="{Binding StatusColor}" CornerRadius="8" Height="28" VerticalAlignment="Center" HorizontalAlignment="Right" Padding="10,0">
                                                            <TextBlock Text="{Binding Status}" Foreground="White" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </Grid>
                                                    <Border Padding="12" BorderBrush="#4d4d4d" BorderThickness="0,0,0,1" Opacity="0.8"/>
                                                    <TextBlock Text="{Binding Description}" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <TabItem Header="Рахунки">
                    <Grid Margin="0,10,0,0">
                        <TextBlock Text="НУ клієнта немає клієнта." Foreground="#888888" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   IsVisible="{Binding Bills.Count, Converter={StaticResource HasItems}, ConverterParameter=invert}"/>
                        <ScrollViewer IsVisible="{Binding Bills.Count, Converter={StaticResource HasItems}}">
                            <ItemsControl ItemsSource="{Binding Bills}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:BillRow">
                                        <Border Padding="12" BorderBrush="White" BorderThickness="0,0,0,1" Opacity="0.8">
                                            <Grid ColumnDefinitions="170,*,160,130">
                                                <TextBlock Grid.Column="0" Text="{Binding Date}" Foreground="#B0B0B0" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Amount}" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Paid}" Foreground="#B0B0B0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                <Border Grid.Column="3" Background="{Binding PaidColor}" CornerRadius="8" Height="28" VerticalAlignment="Center" HorizontalAlignment="Right" Padding="10,0">
                                                    <TextBlock Text="{Binding Source.PaymentMethod}" Foreground="White" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <Panel IsVisible="{Binding IsAddPetOpen}">
            <Border Background="#88000000"/>
            <Border Width="460" Padding="28" Background="#2B2B2B" CornerRadius="14" HorizontalAlignment="Center" VerticalAlignment="Center" DataContext="{Binding AddPetForm}" x:DataType="vm:AddPetViewModel">
                <StackPanel Spacing="14">
                    <TextBlock Text="Нова Тварина" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBox Watermark="Кличка *" Classes="DarkInput" Text="{Binding Name}" Height="42"/>

                    <StackPanel Spacing="6">
                        <TextBlock Text="ВИД *" Classes="Header"/>
                        <Grid ColumnDefinitions="*,8,Auto" IsVisible="{Binding !IsAddingSpecies}">
                            <ComboBox Grid.Column="0" ItemsSource="{Binding SpeciesOptions}" SelectedItem="{Binding SelectedSpecies}" Height="42"
                                      Background="#3A3A3A" BorderThickness="0" CornerRadius="10"/>
                            <Button Grid.Column="2" Content="+ Вид" Height="42" Padding="14,0"
                                    Background="#3A3A3A" CornerRadius="10" BorderThickness="0"
                                    Foreground="White" FontWeight="SemiBold"
                                    Command="{Binding ShowAddSpeciesCommand}"/>
                        </Grid>

                        <Border IsVisible="{Binding IsAddingSpecies}" Background="#252525" CornerRadius="10" Padding="12">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Новий вид" Foreground="#CFCFCF" FontSize="12" FontWeight="SemiBold"/>
                                <TextBox Watermark="Ім'я виду" Classes="DarkInput" Text="{Binding NewSpeciesName}" Height="40"/>
                                <Grid ColumnDefinitions="*,8,*">
                                    <Button Grid.Column="0" Content="Скасувати" Height="38" Background="#3A3A3A" CornerRadius="8" BorderThickness="0" Foreground="#AAAAAA" Command="{Binding CancelAddSpeciesCommand}"/>
                                    <Button Grid.Column="2" Content="Зберегти" Height="38" Background="#4A7C59" CornerRadius="8" BorderThickness="0" Foreground="White" FontWeight="SemiBold" Command="{Binding SaveSpeciesCommand}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Порода" Classes="Header"/>
                        <Grid ColumnDefinitions="*,8,Auto" IsVisible="{Binding !IsAddingBreed}">
                            <ComboBox Grid.Column="0" ItemsSource="{Binding BreedOptions}" SelectedItem="{Binding SelectedBreed}" Height="42"
                                      IsEnabled="{Binding SelectedSpecies, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                      Background="#3A3A3A" BorderThickness="0" CornerRadius="10"/>
                            <Button Grid.Column="2" Content="+ Порода" Height="42" Padding="14,0"
                                    Background="#3A3A3A" CornerRadius="10" BorderThickness="0"
                                    Foreground="White" FontWeight="SemiBold"
                                    IsEnabled="{Binding SelectedSpecies, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    Command="{Binding ShowAddBreedCommand}"/>
                        </Grid>

                        <Border IsVisible="{Binding IsAddingBreed}" Background="#252525" CornerRadius="10" Padding="12">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Нова порода" Foreground="#CFCFCF" FontSize="12" FontWeight="SemiBold"/>
                                <TextBox Watermark="Ім'я породи" Classes="DarkInput" Text="{Binding NewBreedName}" Height="40"/>
                                <Grid ColumnDefinitions="*,8,*">
                                    <Button Grid.Column="0" Content="Cancel" Height="38" Background="#3A3A3A" CornerRadius="8" BorderThickness="0" Foreground="#AAAAAA" Command="{Binding CancelAddBreedCommand}"/>
                                    <Button Grid.Column="2" Content="Save" Height="38" Background="#4A7C59" CornerRadius="8" BorderThickness="0" Foreground="White" FontWeight="SemiBold" Command="{Binding SaveBreedCommand}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="ДАТА НАРОДЖЕННЯ" Classes="Header"/>
                        <Grid ColumnDefinitions="*,8,*,8,*" Margin="0,0,0,2">
                            <TextBlock Grid.Column="0" Text="Day" Foreground="#666666" FontSize="11" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="Month" Foreground="#666666" FontSize="11" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="Year" Foreground="#666666" FontSize="11" HorizontalAlignment="Center"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,8,*,8,*">
                            <ComboBox Grid.Column="0" ItemsSource="{Binding BirthDays}" SelectedItem="{Binding SelectedBirthDay}" Height="42" Background="#3A3A3A" BorderThickness="0" CornerRadius="10"/>
                            <ComboBox Grid.Column="2" ItemsSource="{Binding BirthMonths}" SelectedItem="{Binding SelectedBirthMonth}" Height="42" Background="#3A3A3A" BorderThickness="0" CornerRadius="10"/>
                            <ComboBox Grid.Column="4" ItemsSource="{Binding BirthYears}" SelectedItem="{Binding SelectedBirthYear}" Height="42" Background="#3A3A3A" BorderThickness="0" CornerRadius="10"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="ГЕНДЕР" Classes="Header"/>
                        <ComboBox ItemsSource="{Binding Genders}" SelectedItem="{Binding SelectedGender}" Height="42"
                                  Background="#3A3A3A" BorderThickness="0" CornerRadius="10"/>
                    </StackPanel>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF6B6B" IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" FontSize="13" HorizontalAlignment="Center"/>
                    <Grid ColumnDefinitions="*,10,*" Margin="0,4,0,0">
                        <Button Grid.Column="0" Content="Cancel" Height="42" Background="#3A3A3A" CornerRadius="10" BorderThickness="0" Foreground="#AAAAAA" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding CancelCommand}"/>
                        <Button Grid.Column="2" Content="Save" Height="42" Background="#4A7C59" CornerRadius="10" BorderThickness="0" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding SaveCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Panel>

        <Panel IsVisible="{Binding IsAddAppointmentOpen}">
            <Border Background="#88000000"/>
            <Border Width="500" Padding="28" Background="#2B2B2B" CornerRadius="14" HorizontalAlignment="Center" VerticalAlignment="Center" DataContext="{Binding AddAppointmentForm}" x:DataType="vm:AddAppointmentViewModel">
                <StackPanel Spacing="14">
                    <TextBlock Text="Новий Запис на прийом" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>

                    <TextBlock Text="Тварина *" Classes="Header"/>
                    <ComboBox ItemsSource="{Binding PetOptions}" SelectedItem="{Binding SelectedPet}" Height="42" Background="#3A3A3A" BorderThickness="0" CornerRadius="10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="models:Pet">
                                <TextBlock Text="{Binding Name}" Foreground="White"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Працівник *" Classes="Header"/>
                    <ComboBox ItemsSource="{Binding StaffOptions}" SelectedItem="{Binding SelectedStaff}" Height="42" Background="#3A3A3A" BorderThickness="0" CornerRadius="10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="models:Staff">
                                <TextBlock Foreground="White">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} {1}">
                                            <Binding Path="LastName"/>
                                            <Binding Path="FirstName"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Послуга" Classes="Header"/>
                    <ComboBox ItemsSource="{Binding ServiceOptions}" SelectedItem="{Binding SelectedService}" Height="42" Background="#3A3A3A" BorderThickness="0" CornerRadius="10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="models:Service">
                                <TextBlock Text="{Binding Name}" Foreground="White"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Дата та Час (DD.MM.YYYY HH:MM) *" Classes="Header"/>
                    <TextBox Classes="DarkInput" Text="{Binding DateText}" Height="42"/>

                    <TextBlock Text="Статус" Classes="Header"/>
                    <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatus}" Height="42" Background="#3A3A3A" BorderThickness="0" CornerRadius="10"/>

                    <TextBlock Text="Опис" Classes="Header"/>
                    <TextBox Classes="DarkInput" Text="{Binding Description}" Height="42"/>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF6B6B" IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" FontSize="13" HorizontalAlignment="Center"/>
                    <Grid ColumnDefinitions="*,10,*" Margin="0,6,0,0">
                        <Button Grid.Column="0" Content="Скасувати" Height="42" Background="#3A3A3A" CornerRadius="10" BorderThickness="0" Foreground="#AAAAAA" Command="{Binding CancelCommand}"/>
                        <Button Grid.Column="2" Content="Зберегти" Height="42" Background="#4A7C59" CornerRadius="10" BorderThickness="0" Foreground="White" FontWeight="SemiBold" Command="{Binding SaveCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Panel>

        <Panel IsVisible="{Binding IsAddBillOpen}">
            <Border Background="#88000000"/>
            <Border Width="500" Padding="28" Background="#2B2B2B" CornerRadius="14" HorizontalAlignment="Center" VerticalAlignment="Center" DataContext="{Binding AddBillForm}" x:DataType="vm:AddBillViewModel">
                <StackPanel Spacing="14">
                    <TextBlock Text="Новий Рахунок" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>

                    <TextBlock Text="Запис *" Classes="Header"/>
                    <ComboBox ItemsSource="{Binding AppointmentOptions}" SelectedItem="{Binding SelectedAppointment}" Height="42" Background="#3A3A3A" BorderThickness="0" CornerRadius="10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="models:Appointment">
                                <TextBlock Foreground="White">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0:dd.MM.yyyy HH:mm} | {1}">
                                            <Binding Path="Date"/>
                                            <Binding Path="Pet.Name"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Загальна ціна *" Classes="Header"/>
                    <TextBox Classes="DarkInput" Text="{Binding TotalAmount}" Height="42"/>

                    <TextBlock Text="Дата та Час (DD.MM.YYYY HH:MM) *" Classes="Header"/>
                    <TextBox Classes="DarkInput" Text="{Binding DateText}" Height="42"/>

                    <TextBlock Text="Статус Оплати" Classes="Header"/>
                    <ComboBox ItemsSource="{Binding PaidOptions}" SelectedItem="{Binding SelectedPaid}" Height="42" Background="#3A3A3A" BorderThickness="0" CornerRadius="10"/>

                    <TextBlock Text="Вид Оплати" Classes="Header"/>
                    <TextBox Classes="DarkInput" Text="{Binding PaymentMethod}" Height="42"/>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF6B6B" IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" FontSize="13" HorizontalAlignment="Center"/>
                    <Grid ColumnDefinitions="*,10,*" Margin="0,6,0,0">
                        <Button Grid.Column="0" Content="Cancel" Height="42" Background="#3A3A3A" CornerRadius="10" BorderThickness="0" Foreground="#AAAAAA" Command="{Binding CancelCommand}"/>
                        <Button Grid.Column="2" Content="Save" Height="42" Background="#4A7C59" CornerRadius="10" BorderThickness="0" Foreground="White" FontWeight="SemiBold" Command="{Binding SaveCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Panel>

        <Panel IsVisible="{Binding IsEditMode}">
            <Border Background="#88000000"/>
            <Border Width="460" Padding="28" Background="#2B2B2B" CornerRadius="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="14">
                    <TextBlock Text="Редагування Клієнта" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBox Watermark="Прізивище *" Classes="DarkInput" Text="{Binding EditLastName}" Height="42"/>
                    <TextBox Watermark="Ім'я *" Classes="DarkInput" Text="{Binding EditFirstName}" Height="42"/>
                    <TextBox Watermark="Телефон *" Classes="DarkInput" Text="{Binding EditPhone}" Height="42"/>
                    <TextBox Watermark="Email" Classes="DarkInput" Text="{Binding EditEmail}" Height="42"/>
                    <TextBlock Text="{Binding EditError}" Foreground="#FF6B6B" IsVisible="{Binding EditError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" FontSize="13" HorizontalAlignment="Center"/>
                    <Grid ColumnDefinitions="*,10,*" Margin="0,8,0,0">
                        <Button Grid.Column="0" Content="Скасувати" Height="42" Background="#3A3A3A" CornerRadius="10" BorderThickness="0" Foreground="#AAAAAA" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding CancelEditCommand}"/>
                        <Button Grid.Column="2" Content="Зберегти" Height="42" Background="#4A7C59" CornerRadius="10" BorderThickness="0" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding SaveEditCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Panel>
    </Panel>
</UserControl>
